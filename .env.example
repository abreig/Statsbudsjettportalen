# Database connection (required)
# Lokalt: Docker-eksponert port 5433 (unngår konflikt med andre prosjekter på port 5432)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5433;Database=statsbudsjett;Username=statsbudsjett;Password=localdev

# JWT secret for mock auth (min 32 chars, change in production)
JwtSettings__Secret=poc-secret-key-not-for-production-use-only-minimum-32-chars

# CORS allowed origins (ikke nødvendig når SPA serveres fra backend)
Cors__AllowedOrigins__0=http://localhost:5173

# Enable Swagger UI i ikke-Development-miljøer
EnableSwagger=true

# Azure App Settings (sett disse i Azure Portal, ikke her)
# ASPNETCORE_ENVIRONMENT=Production
# WEBSITES_PORT=8080
# ConnectionStrings__DefaultConnection=Host=<pg>.postgres.database.azure.com;Database=statsbudsjett;Username=<user>;Password=<pass>;SSL Mode=Require
