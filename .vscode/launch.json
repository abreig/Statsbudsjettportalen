{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Start og debug",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/backend/Statsbudsjettportalen.Api/Statsbudsjettportalen.Api.csproj",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
